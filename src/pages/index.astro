---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const services = [
  { category: 'Hair Care & Treatments', description: 'Scalp treatments and deep conditioning for healthy hair.', count: 2, anchor: 'service-category-0' },
  { category: 'Cut', description: 'Precision cuts for men and women, with blow dry included.', count: 4, anchor: 'service-category-1' },
  { category: 'Perm', description: 'Digital, cold, straight, and volume perms for any look.', count: 9, anchor: 'service-category-2' },
  { category: 'Colour', description: 'Full colour, highlights, balayage, bleach and ammonia-free options.', count: 6, anchor: 'service-category-3' },
  { category: 'Styling', description: 'Professional styling and blowouts for any occasion.', count: 1, anchor: 'service-category-4' },
  { category: 'Makeup & Styling', description: 'Full makeup and updo packages for weddings and special events.', count: 5, anchor: 'service-category-5' },
];

const testimonials = [
  { name: 'Carolyn T.', text: 'Absolutely love this place. The stylists are incredibly skilled and the atmosphere is so relaxing. My digital perm turned out perfect!' },
  { name: 'Jessica L.', text: 'Best hair salon experience I\'ve had in Burnaby. They take their time to understand what you want. Highly recommend for colour treatments.' },
  { name: 'Michelle K.', text: 'I got a volume straightening done here and it was a life-changing experience. The results are stunning and long-lasting.' },
  { name: 'Sarah M.', text: 'Amazing bridal hair and makeup service. They were patient, professional, and made me look and feel beautiful on my wedding day.' },
  { name: 'Tina W.', text: 'Came in for a cut and left feeling like a new person. The staff are so friendly and knowledgeable. Will definitely be back.' },
  { name: 'Rachel P.', text: 'K-SIDE is simply the best. My balayage looks incredible and they always make sure I\'m happy with the result before I leave.' },
];

const faqs = [
  { q: 'Is there parking available?', a: 'Yes — free parking is available in the Saavin Living lot directly in front of the building at 6968 Royal Oak Ave. Street parking is also available nearby.' },
  { q: 'Do you require a deposit to book?', a: 'A deposit may be required for longer services such as perms and colour treatments. This is applied toward your total on the day of your appointment.' },
  { q: 'How long does a digital perm take?', a: 'A digital perm typically takes 2.5 – 4 hours depending on your hair length and texture. We recommend booking a consultation first so we can give you a more accurate estimate.' },
  { q: 'How long does a volume straightening (rebonding) service take?', a: 'Volume straightening usually takes 2 – 3 hours. Results last 4 – 6 months with proper care.' },
  { q: 'What should I do to prepare for my appointment?', a: 'Come with clean, dry hair unless otherwise advised. Bring reference photos if you have a specific style in mind — our stylists love the visual direction!' },
  { q: 'Do you offer consultations?', a: 'Yes, we offer in-person consultations. Call us at (604) 923-1414 or book through our online booking page to schedule one.' },
  { q: 'What is your cancellation policy?', a: 'We ask for at least 24 hours notice for cancellations or rescheduling. Late cancellations may result in a fee.' },
];
---

<Layout
  title="K-SIDE"
  description="K-SIDE Hair Salon in Burnaby, BC — expert haircuts, perms, colour, and bridal styling."
>
  <Navbar />

  <!-- ─── HERO — full-bleed video, white text overlay ──────── -->
  <section id="hero" style="position: relative; width: 100%; height: 100svh; overflow: hidden; background: #000; margin-top: -70px;">
    <video
      style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.55;"
      autoplay muted loop playsinline
    >
      <source src="/hero-video.mov" type="video/mp4" />
    </video>

    <div style="position: relative; z-index: 1; height: 100%; display: flex; flex-direction: column; align-items: flex-start; justify-content: flex-end; padding: 65px 40px; max-width: 1400px; margin: 0 auto; box-sizing: border-box;">
      <p style="font-size: 12px; font-weight: 400; color: #ababab; letter-spacing: 0.01em; margin: 0 0 20px; font-family: var(--font-basegrotesk); text-transform: uppercase;">Hair Salon — Burnaby, BC</p>
      <h1 style="font-size: clamp(50px, 8vw, 65px); font-weight: 300; color: #fff; line-height: 1.15; letter-spacing: 0.01em; margin: 0 0 30px; font-family: var(--font-basegrotesk); max-width: 700px;">
        K-SIDE<br />Hair Salon
      </h1>
      <a
        href="https://book.squareup.com/appointments/oj8bsw2ayc6yto/location/LE021WER1QN40/services"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-inverted"
      >
        Book an Appointment
        <svg class="btn-arrow" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <!-- ─── SERVICES — black editorial band ──────────────────── -->
  <section id="services" style="background: #000; width: 100%;" class="reveal">
    <div style="max-width: 1400px; margin: 0 auto; padding: 65px 40px; box-sizing: border-box;">

      <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 40px; padding-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.2);">
        <h2 style="font-size: 12px; font-weight: 500; color: #fff; letter-spacing: 0.01em; text-transform: uppercase; margin: 0; font-family: var(--font-basegrotesk);">Services</h2>
        <a href="/services" style="font-size: 12px; font-weight: 400; color: #FEBF00; text-decoration: none; letter-spacing: 0.01em; font-family: var(--font-basegrotesk);">View all →</a>
      </div>

      <div style="display: flex; flex-direction: column;">
        {services.map((s, i) => (
          <a
            href={`/services#${s.anchor}`}
            style="display: flex; align-items: baseline; justify-content: space-between; gap: 40px; padding: 22px 0; border-bottom: 1px solid rgba(255,255,255,0.1); text-decoration: none; transition: opacity 0.15s;"
            onmouseover="this.style.opacity='0.6'"
            onmouseout="this.style.opacity='1'"
          >
            <div style="display: flex; align-items: baseline; gap: 25px; flex: 1;">
              <span style="font-size: 12px; font-weight: 400; color: #FEBF00; letter-spacing: 0.01em; font-family: var(--font-basegrotesk); min-width: 20px;">0{i + 1}</span>
              <span style="font-size: 25px; font-weight: 300; color: #fff; line-height: 1.3; letter-spacing: 0.01em; font-family: var(--font-basegrotesk);">{s.category}</span>
            </div>
            <span style="font-size: 14px; font-weight: 300; color: #ababab; letter-spacing: 0.01em; font-family: var(--font-basegrotesk); text-align: right; max-width: 280px; display: none;" class="service-desc">{s.description}</span>
            <span style="font-size: 12px; font-weight: 400; color: #ababab; letter-spacing: 0.01em; font-family: var(--font-basegrotesk); flex-shrink: 0;">{s.count} {s.count === 1 ? 'service' : 'services'}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── ABOUT — white section, full-bleed image ──────────── -->
  <section id="about" style="background: #fff; width: 100%;" class="reveal">
    <div style="max-width: 1400px; margin: 0 auto; padding: 65px 40px; box-sizing: border-box; display: grid; grid-template-columns: 1fr 1fr; gap: 65px; align-items: center;">
      <div>
        <p style="font-size: 12px; font-weight: 400; color: #ababab; letter-spacing: 0.01em; text-transform: uppercase; margin: 0 0 20px; font-family: var(--font-basegrotesk);">Our Story</p>
        <h2 style="font-size: 50px; font-weight: 300; color: #000; line-height: 1.17; letter-spacing: 0.01em; margin: 0 0 30px; font-family: var(--font-basegrotesk);">
          More than a haircut.<br />A feeling.
        </h2>
        <hr style="border: none; border-top: 1px solid #000; margin: 0 0 30px;" />
        <p style="font-size: 18px; font-weight: 300; color: #000; line-height: 1.4; letter-spacing: 0.01em; margin: 0 0 20px; font-family: var(--font-basegrotesk);">
          K-SIDE is a boutique hair salon dedicated to bringing out the best in every client through skilled technique and personalised care.
        </p>
        <p style="font-size: 16px; font-weight: 300; color: #ababab; line-height: 1.6; letter-spacing: 0.01em; margin: 0; font-family: var(--font-basegrotesk);">
          Based in Burnaby, BC, we specialise in Korean hair techniques including digital perms, volume straightening, and advanced colour treatments.
        </p>
      </div>
      <div style="overflow: hidden;">
        <img
          src="/images/about.png"
          alt="K-SIDE Hair Salon interior"
          style="width: 100%; aspect-ratio: 3/4; object-fit: cover; display: block;"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ─── GALLERY — black band with photo placeholders ─────── -->
  <section id="gallery" style="background: #000; width: 100%;" class="reveal">
    <div style="max-width: 1400px; margin: 0 auto; padding: 65px 40px 0; box-sizing: border-box;">
      <p style="font-size: 12px; font-weight: 400; color: #ababab; letter-spacing: 0.01em; text-transform: uppercase; margin: 0 0 20px; font-family: var(--font-basegrotesk);">The Space</p>
      <h2 style="font-size: 50px; font-weight: 300; color: #fff; line-height: 1.17; letter-spacing: 0.01em; margin: 0 0 40px; font-family: var(--font-basegrotesk);">Step Inside</h2>
    </div>
    <div class="gallery-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px;">
      {['inside1', 'inside2', 'inside3'].map(name => (
        <div style="aspect-ratio: 1/1; overflow: hidden;">
          <img src={`/images/${name}.png`} alt="K-SIDE salon interior" style="width: 100%; height: 100%; object-fit: cover; display: block;" loading="lazy" />
        </div>
      ))}
    </div>
  </section>

  <!-- ─── STACKING SCROLL — image stack on scroll ─────────── -->
  <section id="stack-section" style="position: relative;">

    <!-- Intro text — white, sticks while images scroll in -->
    <div style="position: sticky; top: 0; height: 100vh; background: #fff; display: flex; align-items: center; z-index: 0; pointer-events: none;">
      <div style="max-width: 1400px; margin: 0 auto; padding: 40px; box-sizing: border-box; width: 100%;">
        <p style="font-size: 12px; font-weight: 400; color: #FEBF00; letter-spacing: 0.01em; text-transform: uppercase; margin: 0 0 20px; font-family: var(--font-basegrotesk);">The Experience</p>
        <h2 style="font-size: clamp(40px, 5vw, 65px); font-weight: 300; color: #000; line-height: 1.15; letter-spacing: 0.01em; margin: 0; font-family: var(--font-basegrotesk); max-width: 700px;">
          Perfect your hair<br />in a perfect environment.
        </h2>
      </div>
    </div>

    <!-- Stacking images — each sticks on top of the previous -->
    {[
      { n: '1', rot: '-2.5deg' },
      { n: '2', rot:  '1.8deg' },
      { n: '3', rot: '-1.2deg' },
      { n: '4', rot:  '2.8deg' },
      { n: '5', rot: '-1.8deg' },
    ].map(({ n, rot }, i) => (
      <div
        class="stack-frame"
        data-index={i}
        style={`position: sticky; top: 0; height: 100vh; z-index: ${i + 1}; background: #fff; display: flex; align-items: center; justify-content: center;`}
      >
        <img
          src={`/images/${n}.png`}
          alt={`K-SIDE salon photo ${n}`}
          style={`width: 70%; height: 80vh; object-fit: cover; display: block; transform: rotate(${rot}); box-shadow: 0 8px 40px rgba(0,0,0,0.18);`}
          class="stack-img"
          loading="lazy"
        />
      </div>
    ))}
  </section>

  <!-- ─── INSTAGRAM — white section ────────────────────────── -->
  <section style="background: #FEBF00;" class="reveal">
    <div style="max-width: 1400px; margin: 0 auto; padding: 40px; box-sizing: border-box; display: flex; align-items: center; justify-content: space-between; gap: 40px; flex-wrap: wrap;">
      <div>
        <p style="font-size: 12px; font-weight: 400; color: rgba(0,0,0,0.5); letter-spacing: 0.01em; text-transform: uppercase; margin: 0 0 8px; font-family: var(--font-basegrotesk);">Follow Along</p>
        <p style="font-size: 25px; font-weight: 300; color: #000; line-height: 1.3; letter-spacing: 0.01em; margin: 0; font-family: var(--font-basegrotesk);">See our latest work on Instagram</p>
      </div>
      <a
        href="https://www.instagram.com/k_side_hairsalon"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
        style="background: #000; color: #FEBF00;"
      >
        @k_side_hairsalon
        <svg class="btn-arrow" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <!-- ─── TESTIMONIALS — image background, two-column ─────── -->
  <section id="testimonials" style="position: relative; width: 100%; overflow: hidden;" class="reveal">
    <!-- Background image -->
    <img src="/images/inside3.png" alt="" aria-hidden="true" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; filter: brightness(0.3);" />

    <div class="testimonials-grid" style="position: relative; z-index: 1; max-width: 1400px; margin: 0 auto; padding: 80px 40px; box-sizing: border-box; display: grid; grid-template-columns: 2fr 3fr; gap: 80px; align-items: start;">

      <!-- Left: heading + paragraph + CTA -->
      <div style="display: flex; flex-direction: column; min-height: 420px; justify-content: space-between;">
        <div>
          <p style="font-size: 12px; font-weight: 400; color: #FEBF00; letter-spacing: 0.01em; text-transform: uppercase; margin: 0 0 20px; font-family: var(--font-basegrotesk);">Google Reviews</p>
          <h2 style="font-size: clamp(32px, 3.5vw, 50px); font-weight: 300; color: #fff; line-height: 1.17; letter-spacing: 0.01em; margin: 0 0 24px; font-family: var(--font-basegrotesk);">
            What our clients say.
          </h2>
          <p style="font-size: 16px; font-weight: 300; color: rgba(255,255,255,0.6); line-height: 1.6; letter-spacing: 0.01em; margin: 0; font-family: var(--font-basegrotesk);">
            Real experiences from clients at K-SIDE Hair Salon in Burnaby, BC.
          </p>
        </div>

        <!-- CTA at bottom left -->
        <a
          href="https://www.google.com/search?q=K-SIDE+Hair+Salon+Burnaby#lrd=0x548676b34e5cb0fb:0x5a1a1a1a1a1a1a1a,3"
          target="_blank"
          rel="noopener noreferrer"
          style="font-size: 14px; font-weight: 500; color: #fff; text-decoration: none; letter-spacing: 0.01em; font-family: var(--font-basegrotesk); border-bottom: 1px solid rgba(255,255,255,0.4); padding-bottom: 4px; display: inline-flex; align-items: center; gap: 8px; width: fit-content; transition: opacity 0.15s;"
          onmouseover="this.style.opacity='0.6'"
          onmouseout="this.style.opacity='1'"
        >
          Write a review
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <!-- Right: 3 reviews stacked -->
      <div style="border-top: 1px solid rgba(255,255,255,0.2);">
        {testimonials.slice(0, 3).map((t) => (
          <div style="padding: 30px 0; border-bottom: 1px solid rgba(255,255,255,0.2);">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px;">
              <p style="font-size: 12px; font-weight: 500; color: #FEBF00; letter-spacing: 0.01em; margin: 0; font-family: var(--font-basegrotesk); text-transform: uppercase;">{t.name}</p>
              <span style="color: #FEBF00; font-size: 12px; letter-spacing: 2px;">★★★★★</span>
            </div>
            <p style="font-size: 16px; font-weight: 300; color: rgba(255,255,255,0.85); line-height: 1.6; letter-spacing: 0.01em; margin: 0; font-family: var(--font-basegrotesk);">"{t.text}"</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ─── CONTACT — white section ──────────────────────────── -->
  <section id="contact" style="background: #fff; width: 100%;" class="reveal">
    <div style="max-width: 1400px; margin: 0 auto; padding: 65px 40px; box-sizing: border-box; display: grid; grid-template-columns: 1fr 1fr; gap: 65px; align-items: start;">
      <div>
        <p style="font-size: 12px; font-weight: 400; color: #ababab; letter-spacing: 0.01em; text-transform: uppercase; margin: 0 0 20px; font-family: var(--font-basegrotesk);">Find Us</p>
        <h2 style="font-size: 50px; font-weight: 300; color: #000; line-height: 1.17; letter-spacing: 0.01em; margin: 0 0 40px; font-family: var(--font-basegrotesk);">Visit Us</h2>
        <hr style="border: none; border-top: 1px solid #000; margin: 0 0 30px;" />
        <div style="display: flex; flex-direction: column; gap: 22px;">
          <div>
            <p style="font-size: 12px; font-weight: 500; color: #000; letter-spacing: 0.01em; text-transform: uppercase; margin: 0 0 6px; font-family: var(--font-basegrotesk);">Address</p>
            <p style="font-size: 16px; font-weight: 300; color: #000; line-height: 1.6; letter-spacing: 0.01em; margin: 0; font-family: var(--font-basegrotesk);">6968 Royal Oak Ave #102<br />Burnaby, BC V5J 4J3<br /><span style="color: #ababab;">Located in Saavin Living</span></p>
          </div>
          <div>
            <p style="font-size: 12px; font-weight: 500; color: #000; letter-spacing: 0.01em; text-transform: uppercase; margin: 0 0 6px; font-family: var(--font-basegrotesk);">Phone</p>
            <a href="tel:+16049231414" style="font-size: 16px; font-weight: 300; color: #000; text-decoration: none; letter-spacing: 0.01em; font-family: var(--font-basegrotesk);">(604) 923-1414</a>
          </div>
          <div>
            <p style="font-size: 12px; font-weight: 500; color: #000; letter-spacing: 0.01em; text-transform: uppercase; margin: 0 0 6px; font-family: var(--font-basegrotesk);">Hours</p>
            <p style="font-size: 16px; font-weight: 300; color: #000; line-height: 1.6; letter-spacing: 0.01em; margin: 0; font-family: var(--font-basegrotesk);">Monday – Sunday<br /><span style="color: #ababab;">10:00 am – 7:00 pm</span></p>
          </div>
        </div>
      </div>
      <div style="overflow: hidden;">
        <iframe
          title="K-SIDE Hair Salon location"
          src="https://maps.google.com/maps?q=6968+Royal+Oak+Ave+%23102+Burnaby+BC+V5J+4J3&output=embed&hl=en"
          width="100%"
          style="height: 420px; border: 0; display: block;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- ─── FAQ — black section with hairlines ────────────────── -->
  <section id="faq" style="background: #000; width: 100%;" class="reveal">
    <div style="max-width: 1400px; margin: 0 auto; padding: 65px 40px; box-sizing: border-box;">
      <p style="font-size: 12px; font-weight: 400; color: #ababab; letter-spacing: 0.01em; text-transform: uppercase; margin: 0 0 20px; font-family: var(--font-basegrotesk);">FAQ</p>
      <h2 style="font-size: 50px; font-weight: 300; color: #fff; line-height: 1.17; letter-spacing: 0.01em; margin: 0 0 40px; font-family: var(--font-basegrotesk);">Common Questions</h2>
      <div id="faq-list" style="border-top: 1px solid rgba(255,255,255,0.2);">
        {faqs.map((item, i) => (
          <div class="faq-item" style="border-bottom: 1px solid rgba(255,255,255,0.2);">
            <button
              class="faq-trigger"
              aria-expanded="false"
              data-index={i}
              style="width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 20px; padding: 22px 0; background: none; border: none; cursor: pointer; text-align: left;"
            >
              <span style="font-size: 18px; font-weight: 300; color: #fff; letter-spacing: 0.01em; font-family: var(--font-basegrotesk);">{item.q}</span>
              <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#fff" stroke-width="1.5" style="flex-shrink: 0; transition: transform 0.3s ease;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
              </svg>
            </button>
            <div class="faq-body" style="max-height: 0; overflow: hidden; transition: max-height 0.35s ease;">
              <p style="padding-bottom: 22px; font-size: 16px; font-weight: 300; color: #ababab; line-height: 1.6; letter-spacing: 0.01em; margin: 0; font-family: var(--font-basegrotesk);">{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA — white section ───────────────────────────────── -->
  <section style="background: #fff; border-top: 1px solid #000; width: 100%;" class="reveal">
    <div style="max-width: 1400px; margin: 0 auto; padding: 65px 40px; box-sizing: border-box; display: flex; align-items: center; justify-content: space-between; gap: 40px; flex-wrap: wrap;">
      <h2 style="font-size: clamp(32px, 4vw, 50px); font-weight: 300; color: #000; line-height: 1.2; letter-spacing: 0.01em; margin: 0; font-family: var(--font-basegrotesk);">
        Ready for your new look?
      </h2>
      <a
        href="https://book.squareup.com/appointments/oj8bsw2ayc6yto/location/LE021WER1QN40/services"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
        style="font-size: 16px; flex-shrink: 0;"
      >
        Book an Appointment
        <svg class="btn-arrow" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <Footer />

  <script>
    // FAQ accordion
    document.querySelectorAll<HTMLButtonElement>('.faq-trigger').forEach(btn => {
      btn.addEventListener('click', () => {
        const body = btn.nextElementSibling as HTMLElement;
        const icon = btn.querySelector('.faq-icon') as HTMLElement;
        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        document.querySelectorAll<HTMLButtonElement>('.faq-trigger').forEach(other => {
          if (other === btn) return;
          other.setAttribute('aria-expanded', 'false');
          (other.nextElementSibling as HTMLElement).style.maxHeight = '0';
          (other.querySelector('.faq-icon') as HTMLElement).style.transform = '';
        });

        if (isOpen) {
          btn.setAttribute('aria-expanded', 'false');
          body.style.maxHeight = '0';
          icon.style.transform = '';
        } else {
          btn.setAttribute('aria-expanded', 'true');
          body.style.maxHeight = body.scrollHeight + 'px';
          icon.style.transform = 'rotate(45deg)';
        }
      });
    });

    // Scroll reveal
    const revealObserver = new IntersectionObserver(
      entries => entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('revealed');
          revealObserver.unobserve(e.target);
        }
      }),
      { threshold: 0.06 }
    );
    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
  </script>

