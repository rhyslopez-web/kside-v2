---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Testimonials from '../components/Testimonials.astro';

const categoryCards = [
  {
    category: 'Hair Care & Treatments',
    tag: 'Scalp + Repair',
    description: 'Scalp treatments and deep conditioning for healthy hair.',
    count: 2,
    anchor: 'service-category-0',
    image: '/images/haircare.jpg',
  },
  {
    category: 'Cut',
    tag: 'Shape + Style',
    description: 'Precision cuts for men and women, with blow dry included.',
    count: 4,
    anchor: 'service-category-1',
    image: '/images/Cut.jpg',
  },
  {
    category: 'Perm',
    tag: 'Wave + Volume',
    description: 'Digital, cold, straight, and volume perms for any look.',
    count: 9,
    anchor: 'service-category-2',
    image: '/images/perm.jpg',
  },
  {
    category: 'Colour',
    tag: 'Tone + Transform',
    description: 'Full colour, highlights, balayage, bleach and ammonia-free options.',
    count: 6,
    anchor: 'service-category-3',
    image: '/images/colour.jpg',
  },
  {
    category: 'Styling',
    tag: 'Finish + Polish',
    description: 'Professional styling and blowouts for any occasion.',
    count: 1,
    anchor: 'service-category-4',
    image: '/images/styling.jpg',
  },
  {
    category: 'Makeup & Styling',
    tag: 'Bridal + Events',
    description: 'Full makeup and updo packages for weddings and special events.',
    count: 5,
    anchor: 'service-category-5',
    image: '/images/makeup.jpg',
  },
];
---

<Layout
  title="K-SIDE"
  description="K-SIDE Hair Salon in Burnaby, BC — expert haircuts, perms, colour, and bridal styling."
>
  <Navbar />

  <!-- ─── HERO ─────────────────────────────────────────────── -->
  <section id="hero" class="min-h-screen flex items-center justify-center px-4 pt-16 relative overflow-hidden" style="background: var(--color-ink);">
    <!-- Background video -->
    <video
      class="absolute inset-0 w-full h-full object-cover"
      style="z-index: 0;"
      autoplay
      muted
      loop
      playsinline
    >
      <source src="/hero-video.mov" type="video/mp4" />
    </video>

    <!-- Dark + blue gradient overlay (above video, below content) -->
    <div class="absolute inset-0 pointer-events-none" style="z-index: 1; background: linear-gradient(to bottom, rgba(14,14,14,0.65) 0%, rgba(14,14,14,0.45) 50%, rgba(14,14,14,0.75) 100%);"></div>

    <!-- Blue glow orb -->
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full blur-[120px] opacity-25 pointer-events-none" style="z-index: 1; background: var(--color-blue);"></div>

    <div class="text-center max-w-3xl mx-auto relative z-10">
      <!-- Eyebrow -->
      <p class="text-xs font-semibold uppercase tracking-[0.35em] mb-8" style="color: var(--color-blue); font-family: var(--font-sans);">
        Hair Salon · Burnaby, BC
      </p>

      <!-- Mixed heading -->
      <h1 class="mb-8 leading-none" style="color: #fff;">
        <span class="heading-mixed block text-6xl sm:text-8xl">K-SIDE</span>
        <span class="block mt-2" style="font-family: var(--font-serif); font-style: italic; font-weight: 300; font-size: clamp(1.5rem, 4vw, 2.5rem); color: rgba(255,255,255,0.55); letter-spacing: 0.05em;">
          where your hair tells your story
        </span>
      </h1>

      <p class="text-base sm:text-lg leading-relaxed mb-12 max-w-md mx-auto" style="color: rgba(255,255,255,0.5); font-family: var(--font-sans); font-weight: 300;">
        Cuts, colour, perms, and bridal styling — crafted for you.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://book.squareup.com/appointments/oj8bsw2ayc6yto/location/LE021WER1QN40/services"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary inline-flex items-center justify-center gap-2.5 px-8 py-3.5 rounded-full font-medium text-sm text-white"
          style="font-family: var(--font-sans);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          Book an Appointment
        </a>
        <a
          href="#services"
          class="btn-ghost inline-flex items-center justify-center gap-2.5 px-8 py-3.5 rounded-full font-medium text-sm"
          style="color: rgba(255,255,255,0.85); font-family: var(--font-sans);"
        >
          View Services
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Scroll nudge -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-30">
      <span class="text-white text-xs tracking-widest uppercase" style="font-family: var(--font-sans);">Scroll</span>
      <div class="w-px h-10 bg-white/40"></div>
    </div>
  </section>

  <script>
    // Desktop-only cursor image trail in the hero section
    if (window.matchMedia('(pointer: fine) and (min-width: 768px)').matches) {
      const hero = document.getElementById('hero');
      if (!hero) throw new Error();

      const images = [
        '/images/467015414_18027706388590881_1090013279111856430_n.jpg',
        '/images/468735055_477348541505442_753108359805719266_n.jpg',
        '/images/473182005_18034634357590881_4510948122913346982_n.jpg',
        '/images/476389691_18037317023590881_375829887713445537_n.jpg',
        '/images/529723164_18057768485590881_1959118319614580428_n.jpg',
        '/images/592585036_18072143828590881_6265024879786207654_n.jpg',
      ];

      const SIZE = 150;
      let index = 0;
      let lastSpawn = 0;
      const THROTTLE = 80;

      hero.addEventListener('mousemove', (e: MouseEvent) => {
        const now = Date.now();
        if (now - lastSpawn < THROTTLE) return;
        lastSpawn = now;

        const rect = hero.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;

        const img = document.createElement('img');
        img.src = images[index % images.length];
        img.alt = '';
        img.style.cssText = `
          position: absolute;
          left: ${x - SIZE / 2}px;
          top: ${y - SIZE / 2}px;
          width: ${SIZE}px;
          height: ${SIZE}px;
          object-fit: cover;
          border-radius: 12px;
          pointer-events: none;
          opacity: 0;
          transform: scale(0.85) rotate(${(Math.random() - 0.5) * 16}deg);
          transition: opacity 0.15s ease, transform 0.15s ease;
          z-index: 5;
          user-select: none;
        `;
        hero.appendChild(img);
        index++;

        requestAnimationFrame(() => {
          img.style.opacity = '0.75';
          img.style.transform = `scale(1) rotate(${(Math.random() - 0.5) * 10}deg)`;
        });

        setTimeout(() => {
          img.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
          img.style.opacity = '0';
          img.style.transform = `scale(0.9) translateY(-24px) rotate(${(Math.random() - 0.5) * 8}deg)`;
        }, 350);

        setTimeout(() => img.remove(), 900);
      });
    }
  </script>

  <!-- ─── SERVICES OVERVIEW ────────────────────────────────── -->
  <section id="services" class="py-24 px-4 reveal" style="background: var(--color-bg);">
    <div class="max-w-6xl mx-auto flex flex-col lg:flex-row gap-16 items-start">

      <!-- Left: heading + description -->
      <div class="lg:sticky lg:top-28 lg:w-72 flex-shrink-0">
        <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-blue); font-family: var(--font-sans);">What We Offer</p>
        <h2 class="heading-mixed text-4xl sm:text-5xl mb-6" style="color: var(--color-ink);">
          Our <em>Services</em>
        </h2>
        <p class="text-base leading-relaxed mb-8" style="color: var(--color-muted); font-family: var(--font-sans); font-weight: 300;">
          From precision cuts and transformative perms to vivid colour and bridal styling — every service is tailored to you.
        </p>
        <a
          href="/services"
          class="btn-primary inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-medium"
          style="color: #fff; font-family: var(--font-sans);"
        >
          View All Services
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Right: category cards, 2-col grid -->
      <div class="flex-1 grid grid-cols-1 sm:grid-cols-2 gap-5">
        {categoryCards.map(card => (
          <a
            href={`/services#${card.anchor}`}
            class="group rounded-2xl overflow-hidden flex flex-col hover:shadow-lg transition-shadow duration-300"
            style="background: var(--color-surface); border: 1px solid var(--color-border); text-decoration: none;"
          >
            <!-- 4:3 image -->
            <div class="overflow-hidden" style="aspect-ratio: 4/3;">
              <img
                src={card.image}
                alt={card.category}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>

            <!-- Info + button -->
            <div class="p-5 flex flex-col flex-grow">
              <p class="text-xs font-semibold uppercase tracking-widest mb-1" style="color: var(--color-blue); font-family: var(--font-sans);">{card.tag}</p>
              <h3 class="text-lg font-semibold mb-1 leading-snug" style="font-family: var(--font-serif); font-size: 1.2rem; color: var(--color-ink);">{card.category}</h3>
              <p class="text-sm leading-relaxed flex-grow mb-4" style="color: var(--color-muted); font-family: var(--font-sans);">{card.description}</p>
              <div class="flex items-center justify-between pt-3" style="border-top: 1px solid var(--color-border);">
                <span class="text-xs" style="color: var(--color-muted); font-family: var(--font-sans);">
                  {card.count} {card.count === 1 ? 'service' : 'services'}
                </span>
                <span class="inline-flex items-center gap-1.5 text-xs font-medium" style="color: var(--color-blue); font-family: var(--font-sans);">
                  Explore
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- ─── ABOUT ─────────────────────────────────────────────── -->
  <section id="about" class="py-24 px-4 reveal" style="background: var(--color-surface);">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <!-- About image -->
      <div class="aspect-[3/4] rounded-3xl overflow-hidden">
        <img
          src="/images/about.jpg"
          alt="K-SIDE Hair Salon — about us"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-blue); font-family: var(--font-sans);">Our Story</p>
        <h2 class="heading-mixed text-4xl sm:text-5xl mb-8 leading-tight" style="color: var(--color-ink);">
          More than a haircut —<br /><em>a feeling.</em>
        </h2>
        <p class="text-base leading-relaxed mb-5" style="color: var(--color-muted); font-family: var(--font-sans); font-weight: 300;">
          K-SIDE is a boutique hair salon dedicated to bringing out the best in every client through skilled technique and personalised care.
        </p>
        <p class="text-base leading-relaxed" style="color: var(--color-muted); font-family: var(--font-sans); font-weight: 300;">
          Based in Burnaby, BC, we specialise in Korean hair techniques including digital perms, volume straightening, and advanced colour treatments.
        </p>
      </div>
    </div>
  </section>

  <!-- ─── GALLERY ───────────────────────────────────────────── -->
  <section id="gallery" class="py-24 px-4 reveal" style="background: var(--color-bg);">
    <div class="max-w-6xl mx-auto">
      <div class="mb-14">
        <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-blue); font-family: var(--font-sans);">Our Work</p>
        <h2 class="heading-mixed text-4xl sm:text-5xl" style="color: var(--color-ink);">
          <em>Gallery</em>
        </h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {[
          '467015414_18027706388590881_1090013279111856430_n.jpg',
          '468735055_477348541505442_753108359805719266_n.jpg',
          '473182005_18034634357590881_4510948122913346982_n.jpg',
          '476389691_18037317023590881_375829887713445537_n.jpg',
          '529723164_18057768485590881_1959118319614580428_n.jpg',
          '592585036_18072143828590881_6265024879786207654_n.jpg',
        ].map((filename, i) => (
          <div class="aspect-square overflow-hidden rounded-2xl">
            <img
              src={`/images/${filename}`}
              alt={`K-SIDE Hair Salon — gallery photo ${i + 1}`}
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a
          href="https://www.instagram.com/k_side_hairsalon"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium transition-opacity hover:opacity-60"
          style="color: var(--color-muted); font-family: var(--font-sans);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          See more on Instagram
        </a>
      </div>
    </div>
  </section>

  <Testimonials />

  <!-- ─── LOCATION ────────────────────────────────────────────── -->
  <section id="contact" class="py-24 px-4 reveal" style="background: var(--color-surface);">
    <div class="max-w-6xl mx-auto">

      <div class="mb-12">
        <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-blue); font-family: var(--font-sans);">Find Us</p>
        <h2 class="heading-mixed text-4xl sm:text-5xl" style="color: var(--color-ink);">
          Visit <em>Us</em>
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">

        <!-- Info panel -->
        <div class="flex flex-col gap-8">

          <!-- Address -->
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background: var(--color-blue-tint);">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" style="color: var(--color-blue);">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest mb-1" style="color: var(--color-blue); font-family: var(--font-sans);">Address</p>
              <p class="text-base" style="color: var(--color-ink); font-family: var(--font-sans);">6968 Royal Oak Ave #102</p>
              <p class="text-base" style="color: var(--color-ink); font-family: var(--font-sans);">Burnaby, BC V5J 4J3</p>
              <p class="text-sm mt-1" style="color: var(--color-muted); font-family: var(--font-sans);">Located in Saavin Living</p>
            </div>
          </div>

          <!-- Phone -->
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background: var(--color-blue-tint);">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" style="color: var(--color-blue);">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest mb-1" style="color: var(--color-blue); font-family: var(--font-sans);">Phone</p>
              <a href="tel:+16049231414" class="text-base hover:opacity-70 transition-opacity" style="color: var(--color-ink); font-family: var(--font-sans);">(604) 923-1414</a>
            </div>
          </div>

          <!-- Hours -->
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background: var(--color-blue-tint);">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" style="color: var(--color-blue);">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest mb-1" style="color: var(--color-blue); font-family: var(--font-sans);">Hours</p>
              <p class="text-base" style="color: var(--color-ink); font-family: var(--font-sans);">Monday – Sunday</p>
              <p class="text-base" style="color: var(--color-muted); font-family: var(--font-sans);">10:00 am – 7:00 pm</p>
            </div>
          </div>

        </div>

        <!-- Map -->
        <div class="w-full rounded-2xl overflow-hidden" style="aspect-ratio: 4/3; border: 1px solid var(--color-border);">
          <iframe
            title="K-SIDE Hair Salon location"
            src="https://maps.google.com/maps?q=6968+Royal+Oak+Ave+%23102+Burnaby+BC+V5J+4J3&output=embed&hl=en"
            width="100%"
            height="100%"
            style="border: 0; display: block;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── FAQ ──────────────────────────────────────────────────── -->
  <section id="faq" class="py-24 px-4 reveal" style="background: var(--color-bg);">
    <div class="max-w-3xl mx-auto">
      <div class="mb-14">
        <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-blue); font-family: var(--font-sans);">Got Questions?</p>
        <h2 class="heading-mixed text-4xl sm:text-5xl" style="color: var(--color-ink);">
          Frequently <em>Asked</em>
        </h2>
      </div>

      <div id="faq-list" class="flex flex-col" style="border-top: 1px solid var(--color-border);">
        {[
          {
            q: 'Is there parking available?',
            a: 'Yes — free parking is available in the Saavin Living lot directly in front of the building at 6968 Royal Oak Ave. Street parking is also available nearby.',
          },
          {
            q: 'Do you require a deposit to book?',
            a: 'A deposit may be required for longer services such as perms and colour treatments. This is applied toward your total on the day of your appointment.',
          },
          {
            q: 'How long does a digital perm take?',
            a: 'A digital perm typically takes 2.5 – 4 hours depending on your hair length and texture. We recommend booking a consultation first so we can give you a more accurate estimate.',
          },
          {
            q: 'How long does a volume straightening (rebonding) service take?',
            a: 'Volume straightening usually takes 2 – 3 hours. Results last 4 – 6 months with proper care.',
          },
          {
            q: 'What should I do to prepare for my appointment?',
            a: 'Come with clean, dry hair unless otherwise advised. Bring reference photos if you have a specific style in mind — our stylists love the visual direction!',
          },
          {
            q: 'Do you offer consultations?',
            a: 'Yes, we offer in-person consultations. Call us at (604) 923-1414 or book through our online booking page to schedule one.',
          },
          {
            q: 'What is your cancellation policy?',
            a: 'We ask for at least 24 hours notice for cancellations or rescheduling. Late cancellations may result in a fee.',
          },
        ].map((item, i) => (
          <div class="faq-item" style="border-bottom: 1px solid var(--color-border);">
            <button
              class="faq-trigger w-full flex items-center justify-between gap-4 py-5 text-left"
              aria-expanded="false"
              data-index={i}
            >
              <span class="text-base font-medium" style="color: var(--color-ink); font-family: var(--font-sans);">{item.q}</span>
              <svg class="faq-icon w-5 h-5 flex-shrink-0 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" style="color: var(--color-blue);">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
              </svg>
            </button>
            <div class="faq-body overflow-hidden" style="max-height: 0; transition: max-height 0.35s ease;">
              <p class="pb-5 text-sm leading-relaxed" style="color: var(--color-muted); font-family: var(--font-sans); font-weight: 300;">{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll<HTMLButtonElement>('.faq-trigger').forEach(btn => {
      btn.addEventListener('click', () => {
        const body = btn.nextElementSibling as HTMLElement;
        const icon = btn.querySelector('.faq-icon') as HTMLElement;
        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        // Close all others
        document.querySelectorAll<HTMLButtonElement>('.faq-trigger').forEach(other => {
          if (other === btn) return;
          other.setAttribute('aria-expanded', 'false');
          (other.nextElementSibling as HTMLElement).style.maxHeight = '0';
          (other.querySelector('.faq-icon') as HTMLElement).style.transform = '';
        });

        if (isOpen) {
          btn.setAttribute('aria-expanded', 'false');
          body.style.maxHeight = '0';
          icon.style.transform = '';
        } else {
          btn.setAttribute('aria-expanded', 'true');
          body.style.maxHeight = body.scrollHeight + 'px';
          icon.style.transform = 'rotate(45deg)';
        }
      });
    });
  </script>

  <Footer />

  <script>
    const revealObserver = new IntersectionObserver(
      entries => entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('revealed');
          revealObserver.unobserve(e.target);
        }
      }),
      { threshold: 0.08 }
    );
    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
  </script>
</Layout>
