---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import type { Service } from '../types/database';

let services: Service[] = [];
try {
  const { supabase } = await import('../lib/supabase');
  const { data, error } = await supabase.from('services').select('*').order('category').order('id');
  if (data && !error) services = data;
} catch {
  const raw = await import('../../services-data.json', { with: { type: 'json' } });
  services = (raw.default as any[]).map((s: any) => ({
    ...s,
    created_at: new Date().toISOString(),
  })) as Service[];
}

const categories = [...new Set(services.map(s => s.category))];
const grouped = Object.fromEntries(
  categories.map(cat => [cat, services.filter(s => s.category === cat)])
);
---

<Layout
  title="Services"
  description="Browse all K-SIDE Hair Salon services — cuts, perms, colour, treatments, styling, and bridal makeup in Burnaby, BC."
>
  <Navbar />

  <!-- Page header — black band -->
  <div style="background: #000; padding: 65px 40px 50px; box-sizing: border-box;">
    <div style="max-width: 1400px; margin: 0 auto;">
      <p style="font-size: 12px; font-weight: 400; color: #FEBF00; letter-spacing: 0.01em; text-transform: uppercase; margin: 0 0 16px; font-family: var(--font-basegrotesk);">What We Offer</p>
      <h1 style="font-size: clamp(40px, 6vw, 65px); font-weight: 300; color: #fff; line-height: 1.15; letter-spacing: 0.01em; margin: 0; font-family: var(--font-basegrotesk);">Services</h1>
    </div>
  </div>

  <!-- Sticky category nav -->
  <div id="category-nav" style="position: sticky; top: 70px; z-index: 45; background: #fff; border-bottom: 1px solid #000; box-sizing: border-box;">
    <div style="display: flex; align-items: center; height: 52px; overflow: hidden;">
      <div style="display: flex; align-items: center; overflow-x: auto; scrollbar-width: none; flex: 1; height: 52px;" id="pills-scroll">
        {categories.map((category, i) => (
          <button
            data-target={`service-category-${i}`}
            class="service-pill"
            style="background: none; border: none; border-right: 1px solid #000; cursor: pointer; padding: 0 28px; height: 52px; font-size: 13px; font-weight: 400; color: #ababab; letter-spacing: 0.01em; font-family: var(--font-basegrotesk); white-space: nowrap; transition: color 0.15s; flex-shrink: 0;"
          >
            {category}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- Services list -->
  <section style="background: #fff; width: 100%;">
    <div style="max-width: 1400px; margin: 0 auto; padding: 0 40px; box-sizing: border-box;">
      {categories.map((category, i) => (
        <div id={`service-category-${i}`} style="padding: 60px 0; border-bottom: 1px solid #000;">
          <!-- Category heading -->
          <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 40px;">
            <div style="display: flex; align-items: baseline; gap: 16px;">
              <span style="font-size: 12px; font-weight: 400; color: #FEBF00; letter-spacing: 0.01em; font-family: var(--font-basegrotesk);">0{i + 1}</span>
              <h2 style="font-size: 32px; font-weight: 300; color: #000; line-height: 1.2; letter-spacing: 0.01em; margin: 0; font-family: var(--font-basegrotesk);">{category}</h2>
            </div>
            <span style="font-size: 12px; font-weight: 300; color: #ababab; letter-spacing: 0.01em; font-family: var(--font-basegrotesk);">{grouped[category].length} {grouped[category].length === 1 ? 'service' : 'services'}</span>
          </div>

          <!-- Service rows -->
          <div style="border-top: 1px solid #e0e0e0;">
            {grouped[category].map((service: Service) => (
              <div
                data-service-title={service.title}
                data-service-category={service.category}
                class="service-row"
                style="display: flex; flex-direction: column; align-items: flex-start; gap: 16px; padding: 28px 0; border-bottom: 1px solid #e0e0e0;"
              >
                <!-- Title + description -->
                <div style="width: 100%;">
                  <h3 style="font-size: 18px; font-weight: 400; color: #000; line-height: 1.3; letter-spacing: 0.01em; margin: 0 0 8px; font-family: var(--font-basegrotesk);">{service.title}</h3>
                  {service.description && (
                    <p style="font-size: 14px; font-weight: 300; color: #ababab; line-height: 1.5; letter-spacing: 0.01em; margin: 0; font-family: var(--font-basegrotesk);">{service.description}</p>
                  )}
                </div>
                <!-- Price + button row -->
                <div style="display: flex; align-items: center; justify-content: space-between; width: 100%; gap: 16px;">
                  <div>
                    <p style="font-size: 16px; font-weight: 400; color: #000; letter-spacing: 0.01em; margin: 0; font-family: var(--font-basegrotesk);">
                      {service.price_varies ? 'Price varies' : (service.price ?? 'Contact us')}
                    </p>
                    {service.duration && (
                      <p style="font-size: 12px; font-weight: 300; color: #ababab; letter-spacing: 0.01em; margin: 4px 0 0; font-family: var(--font-basegrotesk);">{service.duration}</p>
                    )}
                  </div>
                  <a
                    href="https://book.squareup.com/appointments/oj8bsw2ayc6yto/location/LE021WER1QN40/services"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-primary"
                    style="font-size: 13px; padding: 7px 18px; white-space: nowrap; flex-shrink: 0;"
                  >
                    Book
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.service-pill');

  function setActive(active: HTMLButtonElement) {
    pills.forEach(p => {
      p.style.color = '#ababab';
      p.style.background = 'none';
      p.style.fontWeight = '400';
    });
    active.style.color = '#000';
    active.style.background = 'none';
    active.style.fontWeight = '500';
  }

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      const target = document.getElementById(pill.dataset.target!);
      if (!target) return;
      const top = target.getBoundingClientRect().top + window.scrollY - 80;
      window.scrollTo({ top, behavior: 'smooth' });
      setActive(pill);
    });
  });

  // Highlight active pill on scroll
  const sections = document.querySelectorAll<HTMLElement>('[id^="service-category-"]');
  const observer = new IntersectionObserver(
    entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const idx = entry.target.id.replace('service-category-', '');
          pills.forEach((p, i) => {
            const active = String(i) === idx;
            p.style.color = active ? '#000' : '#ababab';
            p.style.fontWeight = active ? '500' : '400';
          });
        }
      });
    },
    { rootMargin: '-20% 0px -70% 0px' }
  );
  sections.forEach(s => observer.observe(s));

</script>

<style>
  #pills-scroll::-webkit-scrollbar { display: none; }

</style>
