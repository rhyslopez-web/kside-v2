---
---

<footer style="background: #fff; border-top: 1px solid #000;">
  <div style="max-width: 1400px; margin: 0 auto; padding: 60px 40px; display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 40px;">

    <!-- Brand -->
    <div>
      <p style="font-size: 16px; font-weight: 500; color: #000; letter-spacing: 0.01em; margin: 0 0 16px; font-family: var(--font-basegrotesk);">K-SIDE</p>
      <p style="font-size: 14px; font-weight: 300; color: #ababab; line-height: 1.7; margin: 0; font-family: var(--font-basegrotesk); letter-spacing: 0.01em;">
        Expert hair care, colour, perms, and bridal styling.<br />
        6968 Royal Oak Ave #102<br />
        Burnaby, BC V5J 4J3<br />
        (604) 923-1414
      </p>
    </div>

    <!-- Navigate -->
    <div>
      <p style="font-size: 12px; font-weight: 500; color: #000; letter-spacing: 0.01em; text-transform: uppercase; margin: 0 0 16px; font-family: var(--font-basegrotesk);">Navigate</p>
      <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 10px;">
        <li><a href="/#services" style="font-size: 14px; font-weight: 300; color: #ababab; text-decoration: none; letter-spacing: 0.01em; font-family: var(--font-basegrotesk); transition: color 0.15s;" onmouseover="this.style.color='#000'" onmouseout="this.style.color='#ababab'">Services</a></li>
        <li><a href="/#about" style="font-size: 14px; font-weight: 300; color: #ababab; text-decoration: none; letter-spacing: 0.01em; font-family: var(--font-basegrotesk); transition: color 0.15s;" onmouseover="this.style.color='#000'" onmouseout="this.style.color='#ababab'">About</a></li>
        <li><a href="/#gallery" style="font-size: 14px; font-weight: 300; color: #ababab; text-decoration: none; letter-spacing: 0.01em; font-family: var(--font-basegrotesk); transition: color 0.15s;" onmouseover="this.style.color='#000'" onmouseout="this.style.color='#ababab'">Gallery</a></li>
        <li><a href="/#contact" style="font-size: 14px; font-weight: 300; color: #ababab; text-decoration: none; letter-spacing: 0.01em; font-family: var(--font-basegrotesk); transition: color 0.15s;" onmouseover="this.style.color='#000'" onmouseout="this.style.color='#ababab'">Contact</a></li>
      </ul>
    </div>

    <!-- Book -->
    <div>
      <p style="font-size: 12px; font-weight: 500; color: #000; letter-spacing: 0.01em; text-transform: uppercase; margin: 0 0 16px; font-family: var(--font-basegrotesk);">Book</p>
      <a
        href="https://book.squareup.com/appointments/oj8bsw2ayc6yto/location/LE021WER1QN40/services"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
        style="font-size: 14px;"
      >
        Book an Appointment
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>

  </div>

  <div style="border-top: 1px solid #000; max-width: 1400px; margin: 0 auto; padding: 20px 40px;">
    <p style="font-size: 12px; font-weight: 300; color: #ababab; margin: 0; letter-spacing: 0.01em; font-family: var(--font-basegrotesk);">
      &copy; {new Date().getFullYear()} K-SIDE Hair Salon. All rights reserved.
    </p>
  </div>
</footer>

<style>
  @media (max-width: 767px) {
    footer > div:first-of-type {
      grid-template-columns: 1fr !important;
    }
  }
</style>
