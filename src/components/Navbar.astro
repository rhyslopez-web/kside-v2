---
const navLinks = [
  { label: 'Services', href: '/services' },
  { label: 'About', href: '/#about' },
  { label: 'Gallery', href: '/#gallery' },
  { label: 'Reviews', href: '/#testimonials' },
  { label: 'Contact', href: '/#contact' },
];
---

<header id="site-header" style="position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: transparent; transition: background 0.3s ease;">
  <nav style="max-width: 1400px; margin: 0 auto; padding: 0 40px; height: 70px; display: flex; align-items: center; justify-content: space-between;">

    <!-- Logo -->
    <a href="/" style="display: flex; align-items: center; text-decoration: none; flex-shrink: 0;">
      <img id="nav-logo" src="/images/logo.png" alt="K-SIDE Hair Salon" style="height: 36px; width: auto; filter: brightness(0) invert(1); transition: filter 0.3s ease;" />
    </a>

    <!-- Desktop nav links -->
    <ul style="display: flex; gap: 25px; list-style: none; margin: 0; padding: 0;" class="desktop-nav">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="nav-link"
            style="font-size: 14px; font-weight: 400; color: rgba(255,255,255,0.7); text-decoration: none; letter-spacing: 0.01em; font-family: var(--font-basegrotesk); transition: color 0.3s ease;"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop Book Now + mobile hamburger -->
    <div style="display: flex; align-items: center; gap: 20px;">
      <a
        href="https://book.squareup.com/appointments/oj8bsw2ayc6yto/location/LE021WER1QN40/services"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary desktop-book"
        style="font-size: 14px;"
      >
        Book Now
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
      <button id="mobile-menu-btn" aria-label="Open menu" class="mobile-only" style="display: none; background: none; border: none; cursor: pointer; padding: 4px; color: #fff; transition: color 0.3s ease;">
        <svg id="hamburger-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="display:none;">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile full-screen drawer — covers entire viewport -->
<div
  id="mobile-menu"
  style="display: none; position: fixed; inset: 0; z-index: 49; background: #fff; flex-direction: column; justify-content: space-between; padding: 100px 32px 48px;"
>
  <!-- Nav links -->
  <div style="display: flex; flex-direction: column;">
    {navLinks.map(link => (
      <a
        href={link.href}
        class="mobile-nav-link"
        style="font-size: 36px; font-weight: 300; color: #000; text-decoration: none; padding: 18px 0; border-bottom: 1px solid #000; letter-spacing: 0.01em; font-family: var(--font-basegrotesk);"
      >
        {link.label}
      </a>
    ))}
  </div>

  <!-- Book Now pinned to bottom -->
  <a
    href="https://book.squareup.com/appointments/oj8bsw2ayc6yto/location/LE021WER1QN40/services"
    target="_blank"
    rel="noopener noreferrer"
    class="btn-primary"
    style="font-size: 16px; justify-content: center; width: 100%; box-sizing: border-box;"
  >
    Book an Appointment
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
  </a>
</div>

<style>
  @media (max-width: 767px) {
    .desktop-nav { display: none !important; }
    .desktop-book { display: none !important; }
    .mobile-only { display: block !important; }
  }

  /* Reduce section X padding on mobile globally */
  @media (max-width: 767px) {
    [style*=" 40px"],
    [style*=":40px"],
    [style*="padding-left: 40px"],
    [style*="padding-right: 40px"] {
      padding-left: 5px !important;
      padding-right: 5px !important;
    }
  }
</style>

<script>
  // ── Transparent → solid on scroll ──────────────────────────
  const header = document.getElementById('site-header') as HTMLElement;
  const logo = document.getElementById('nav-logo') as HTMLImageElement;
  const navLinks = document.querySelectorAll<HTMLElement>('.nav-link');
  const menuBtn2 = document.getElementById('mobile-menu-btn') as HTMLElement;

  function setScrolled(scrolled: boolean) {
    if (scrolled) {
      header.style.background = '#fff';
      if (logo) logo.style.filter = 'brightness(0)';
      navLinks.forEach(l => { l.style.color = 'rgba(0,0,0,0.6)'; });
      if (menuBtn2) menuBtn2.style.color = '#000';
    } else {
      header.style.background = 'transparent';
      if (logo) logo.style.filter = 'brightness(0) invert(1)';
      navLinks.forEach(l => { l.style.color = 'rgba(255,255,255,0.7)'; });
      if (menuBtn2) menuBtn2.style.color = '#fff';
    }
  }

  setScrolled(window.scrollY > 10);
  window.addEventListener('scroll', () => setScrolled(window.scrollY > 10), { passive: true });

  // ── Mobile menu ─────────────────────────────────────────────
  const menuBtn = document.getElementById('mobile-menu-btn') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu') as HTMLElement;
  const hamburger = document.getElementById('hamburger-icon') as HTMLElement;
  const close = document.getElementById('close-icon') as HTMLElement;
  const mobileLinks = document.querySelectorAll<HTMLElement>('.mobile-nav-link');

  let open = false;

  function openMenu() {
    open = true;
    menu.style.display = 'flex';
    hamburger.style.display = 'none';
    close.style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    open = false;
    menu.style.display = 'none';
    hamburger.style.display = 'block';
    close.style.display = 'none';
    document.body.style.overflow = '';
  }

  menuBtn?.addEventListener('click', () => open ? closeMenu() : openMenu());
  mobileLinks.forEach(l => l.addEventListener('click', closeMenu));
</script>
